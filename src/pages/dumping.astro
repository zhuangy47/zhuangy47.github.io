---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const entries = await getCollection('dumping');

entries.sort((a, b) => {
  const hasDateA = Boolean(a.data.date);
  const hasDateB = Boolean(b.data.date);

  if (!hasDateA && hasDateB) return -1;
  if (hasDateA && !hasDateB) return 1;
  
  if (hasDateA && hasDateB) {
    return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
  }
  
  return a.data.title.localeCompare(b.data.title);
});

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);

const formatDate = (date) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};
---

<Base title="Dumping Grounds — Yanni Zhuang" description="Things I find interesting.">
  <a href="/unserious" class="inline-block mt-8 mb-8 text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent transition-colors">
    <span aria-hidden="true">&larr;</span> Home
  </a>

  <h1 class="text-2xl font-bold tracking-tight mb-2">Dumping Grounds</h1>
  <p class="text-sm text-neutral-500 mb-8">interesting things on the interwebs</p>

  {rendered.length === 0 ? (
    <p class="text-sm text-neutral-500">Coming soon.</p>
  ) : (
    <ul class="divide-y divide-neutral-200 dark:divide-neutral-800">
      {rendered.map(({ entry, Content }, i) => (
        <li>
          <button
            class="w-full text-left py-4 cursor-pointer group dump-trigger"
            data-index={i}
            data-title={entry.data.title}
            data-url={entry.data.url}
            data-date={entry.data.date ? formatDate(entry.data.date) : ""}
            data-thumbnail={entry.data.thumbnail || ""}
            data-tags={JSON.stringify(entry.data.tags || [])}
          >
            <div class="flex gap-3 items-start">
              {entry.data.thumbnail && (
                <img
                  src={entry.data.thumbnail}
                  alt=""
                  class="w-24 h-16 object-cover rounded shrink-0 mt-0.5"
                />
              )}
              <div class="flex-1 min-w-0">
                <div class="flex justify-between items-baseline gap-4 flex-wrap mb-1">
                  <div class="flex items-baseline gap-2">
                    <span class="font-medium text-sm group-hover:underline">{entry.data.title}</span>
                    {entry.data.date && (
                      <time datetime={new Date(entry.data.date).toISOString()} class="text-xs text-neutral-400 shrink-0">
                        {formatDate(entry.data.date)}
                      </time>
                    )}
                  </div>
                  {entry.data.tags && entry.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {entry.data.tags.map(tag => (
                        <span class="text-xs bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 px-2 py-0.5 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="text-sm text-neutral-500 dark:text-neutral-400 line-clamp-2">
                  <div class="dump-preview" id={`preview-${i}`}></div>
                </div>
              </div>
            </div>
          </button>

          <!-- Hidden full content for modal -->
          <template id={`content-${i}`}>
            <Content />
          </template>
        </li>
      ))}
    </ul>
  )}
</Base>

<dialog
  id="dump-modal"
  class="m-auto bg-transparent p-4 w-full max-w-2xl max-h-[100dvh] backdrop:bg-black/50 backdrop:backdrop-blur-sm open:flex focus:outline-none"
>
  <div class="bg-white dark:bg-neutral-900 rounded-lg shadow-xl w-full max-h-[85vh] overflow-y-auto relative">
    <div class="p-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div class="flex-1 min-w-0">

          <span id="modal-title" class="text-xl text-neutral-800 dark:text-neutral-300 font-bold tracking-tight mb-1"></span>
          <div class="text-sm text-neutral-500 flex items-center flex-wrap gap-2">
            <time id="modal-date" class="hidden"></time>
            <span id="modal-date-divider" class="hidden text-neutral-300 dark:text-neutral-700">•</span>
            <a id="modal-url" href="#" target="_blank" rel="noopener" class="hover:text-neutral-900 dark:hover:text-neutral-100 break-all transition-colors"></a>
          </div>
        </div>
        <form method="dialog">
          <button
            aria-label="Close dialog"
            class="shrink-0 text-neutral-600 dark:text-neutral-400 hover:text-accent transition-colors text-lg leading-none cursor-pointer"
          ><span aria-hidden="true">✕</span></button>
        </form>
      </div>

      <img id="modal-thumbnail" src="" alt="" class="w-full rounded mb-4 hidden" />

      <div id="modal-tags" class="flex flex-wrap gap-1.5 mb-4"></div>

      <hr class="border-neutral-200 dark:border-neutral-800 mb-4" />

      <div
        id="modal-body"
        class="prose prose-sm dark:prose-invert max-w-none prose-neutral prose-a:text-neutral-900 dark:prose-a:text-neutral-100"
      ></div>
    </div>
  </div>
</dialog>

<style>
  /* Optional: Prevents background scrolling when the dialog is open */
  body:has(dialog[open]) {
    overflow: hidden;
  }
</style>

<script>
  const modal = document.getElementById('dump-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalUrl = document.getElementById('modal-url');
  const modalDate = document.getElementById('modal-date');
  const modalDateDivider = document.getElementById('modal-date-divider');
  const modalThumbnail = document.getElementById('modal-thumbnail');
  const modalTags = document.getElementById('modal-tags');
  const modalBody = document.getElementById('modal-body');

  document.querySelectorAll('.dump-trigger').forEach((btn) => {
    const index = btn.dataset.index;
    const tmpl = document.getElementById(`content-${index}`);
    const preview = document.getElementById(`preview-${index}`);
    
    if (tmpl && preview) {
      const clone = tmpl.content.cloneNode(true);
      const text = clone.textContent.trim() || '';
      preview.textContent = text.slice(0, 200) + (text.length > 200 ? '…' : '');
    }

    btn.addEventListener('click', () => {
      const { title, url, date, thumbnail, tags, index } = btn.dataset;
      
      modalTitle.textContent = title;
      modalUrl.textContent = url;
      modalUrl.href = url;
      
      if (date) {
        modalDate.textContent = date;
        modalDate.classList.remove('hidden');
        modalDateDivider.classList.remove('hidden');
      } else {
        modalDate.classList.add('hidden');
        modalDateDivider.classList.add('hidden');
      }

      if (thumbnail) {
        modalThumbnail.src = thumbnail;
        modalThumbnail.classList.remove('hidden');
      } else {
        modalThumbnail.classList.add('hidden');
      }

      modalTags.innerHTML = '';
      const parsedTags = JSON.parse(tags || "[]");
      parsedTags.forEach(tag => {
        const span = document.createElement('span');
        span.className = 'text-xs bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 px-2 py-0.5 rounded';
        span.textContent = tag;
        modalTags.appendChild(span);
      });

      // Body content
      const contentTmpl = document.getElementById(`content-${index}`);
      modalBody.innerHTML = '';
      if (contentTmpl) {
        const contentClone = contentTmpl.content.cloneNode(true);
        modalBody.appendChild(contentClone);
      }

      // Open via native API
      modal.showModal();
    });
  });

  modal.addEventListener('click', (e) => {
    const dialogDimensions = modal.getBoundingClientRect();
    if (
      e.clientX < dialogDimensions.left ||
      e.clientX > dialogDimensions.right ||
      e.clientY < dialogDimensions.top ||
      e.clientY > dialogDimensions.bottom
    ) {
      modal.close();
    }
  });
</script>
