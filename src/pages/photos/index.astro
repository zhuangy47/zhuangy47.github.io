---
import Base from '../../layouts/Base.astro';

const allPhotos = import.meta.glob('../../photos/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG}');

const collections: Record<string, string[]> = {};
for (const path of Object.keys(allPhotos)) {
  // path looks like ../../photos/collection-name/file.jpg
  const parts = path.split('/');
  const collection = parts[parts.length - 2];
  if (collection && collection !== 'photos') {
    if (!collections[collection]) collections[collection] = [];
    collections[collection].push(path);
  }
}

const collectionNames = Object.keys(collections).sort();
---

<Base title="Photography — Yanni Zhuang" description="Photo collections.">
  <a href="/unserious" class="inline-block mt-8 mb-8 text-sm text-neutral-500 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">
    &larr; Home
  </a>

  <h1 class="text-2xl font-bold tracking-tight mb-2">Photography</h1>
  <p class="text-sm text-neutral-500 mb-8">Collections.</p>

  {collectionNames.length === 0 ? (
    <p class="text-sm text-neutral-500">No collections yet.</p>
  ) : (
    <ul class="space-y-2">
      {collectionNames.map(name => (
        <li>
          <a
            href={`/photos/${name}`}
            class="text-sm no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors flex items-baseline gap-3"
          >
            <span class="capitalize">{name.replace(/-/g, ' ')}</span>
            <span class="text-xs text-neutral-400 dark:text-neutral-600">{collections[name].length} photo{collections[name].length !== 1 ? 's' : ''}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>
