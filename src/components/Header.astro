---
---

<header
  class="fixed top-0 left-0 right-0 h-14 z-50 bg-white/85 dark:bg-neutral-950/85 backdrop-blur-md border-b border-neutral-200/60 dark:border-neutral-800/60"
>
  <div class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-accent via-accent-2 to-transparent pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-2xl mx-auto px-6 h-full flex items-center gap-6">

    <a
      href="/"
      class="nav-formal-only font-bold text-sm no-underline shrink-0 hover:text-accent transition-colors"
    >
      Yanni Zhuang<span class="text-accent" aria-hidden="true">.</span>
    </a>
    <a
      href="/unserious"
      class="nav-informal-only font-bold text-sm no-underline shrink-0 hover:text-accent transition-colors"
    >
      Yanni Zhuang<span class="text-accent" aria-hidden="true">.</span>
    </a>

    <nav class="flex items-center gap-5 flex-1" aria-label="Site sections">
      <a href="/#about" class="nav-formal-only text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent transition-colors">About</a>
      <a href="/#education" class="nav-formal-only text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent transition-colors">Education</a>
      <a href="/#experience" class="nav-formal-only text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent transition-colors">Experience</a>
      <a href="/#projects" class="nav-formal-only text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent transition-colors">Projects</a>

      <a
        href="/blog"
        class="text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent transition-colors"
      >Blog</a>

      <div class="nav-informal-only relative group" id="personal-menu">
        <button
          id="personal-menu-button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="personal-menu-list"
          class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-accent transition-colors cursor-pointer bg-transparent border-none p-0 m-0 leading-none font-inherit"
        >
          Personal
        </button>
        <div class="absolute top-full left-0 pt-1 hidden group-hover:block group-focus-within:block min-w-max z-50">
          <div id="personal-menu-list" class="py-1 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded shadow-md">
            <a
              href="/dumping"
              class="block px-4 py-1.5 text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors"
            >
              Dumping Grounds
            </a>
            <a
              href="/photos"
              class="block px-4 py-1.5 text-sm text-neutral-600 dark:text-neutral-400 no-underline hover:text-accent hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors"
            >
              Photography
            </a>
          </div>
        </div>
      </div>
    </nav>

    <button
      id="switch-to-formal"
      class="nav-informal-only text-xs text-neutral-600 dark:text-neutral-400 border border-neutral-300 dark:border-neutral-700 hover:border-accent hover:text-accent transition-colors rounded-full px-3 py-1 cursor-pointer bg-transparent font-inherit leading-none shrink-0"
    >
      serious mode
    </button>

    <button
      id="theme-toggle"
      aria-label="Dark mode"
      aria-pressed="false"
      class="text-neutral-600 dark:text-neutral-400 hover:text-accent transition-colors text-base leading-none shrink-0"
    >
      <span class="dark:hidden" aria-hidden="true">☾</span>
      <span class="hidden dark:inline" aria-hidden="true">☀</span>
    </button>
  </div>
</header>

<script>
  document.getElementById('switch-to-formal')?.addEventListener('click', () => {
    localStorage.setItem('siteMode', 'formal');
    window.location.href = '/';
  });

  // Keep aria-expanded in sync with the hover/focus-driven dropdown
  const menu = document.getElementById('personal-menu');
  const menuButton = document.getElementById('personal-menu-button');
  if (menu && menuButton) {
    const sync = (open: boolean) => menuButton.setAttribute('aria-expanded', String(open));
    menu.addEventListener('mouseenter', () => sync(true));
    menu.addEventListener('mouseleave', () => sync(!!menu.contains(document.activeElement)));
    menu.addEventListener('focusin', () => sync(true));
    menu.addEventListener('focusout', (e) => {
      if (!menu.contains(e.relatedTarget as Node)) sync(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.contains(document.activeElement)) {
        sync(false);
        menuButton.blur();
      }
    });
  }
</script>
