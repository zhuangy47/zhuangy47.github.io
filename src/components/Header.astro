---
---

<header
  class="fixed top-0 left-0 right-0 h-14 z-50 bg-white/85 dark:bg-neutral-950/85 backdrop-blur-md border-b border-neutral-200/60 dark:border-neutral-800/60"
>
  <div class="max-w-2xl mx-auto px-6 h-full flex items-center gap-6">

    <a
      href="/"
      class="nav-formal-only font-bold text-sm no-underline shrink-0 hover:opacity-70 transition-opacity"
    >
      Yanni Zhuang
    </a>
    <a
      href="/unserious"
      class="nav-informal-only font-bold text-sm no-underline shrink-0 hover:opacity-70 transition-opacity"
    >
      Yanni Zhuang
    </a>

    <nav class="flex items-center gap-5 flex-1" aria-label="Site sections">
      <a href="/#about" class="nav-formal-only text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">About</a>
      <a href="/#education" class="nav-formal-only text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Education</a>
      <a href="/#experience" class="nav-formal-only text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Experience</a>
      <a href="/#projects" class="nav-formal-only text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Projects</a>

      <a
        href="/blog"
        class="text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
      >Blog</a>

      <div class="nav-informal-only relative group">
        <button class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors cursor-pointer bg-transparent border-none p-0 m-0 leading-none font-inherit">
          Personal
        </button>
        <div class="absolute top-full left-0 pt-1 hidden group-hover:block min-w-max z-50">
          <div class="py-1 bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 rounded shadow-md">
            <a
              href="/dumping"
              class="block px-4 py-1.5 text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors"
            >
              Dumping Grounds
            </a>
            <a
              href="/photos"
              class="block px-4 py-1.5 text-sm text-neutral-500 dark:text-neutral-400 no-underline hover:text-neutral-900 dark:hover:text-neutral-100 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors"
            >
              Photography
            </a>
          </div>
        </div>
      </div>
    </nav>

    <button
      id="switch-to-formal"
      class="nav-informal-only text-xs text-neutral-400 dark:text-neutral-500 border border-neutral-200 dark:border-neutral-700 hover:border-neutral-400 dark:hover:border-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors rounded-full px-3 py-1 cursor-pointer bg-transparent font-inherit leading-none shrink-0"
    >
      serious mode
    </button>

    <button
      id="theme-toggle"
      aria-label="Toggle dark mode"
      class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors text-base leading-none shrink-0"
    >
      <span class="dark:hidden">☾</span>
      <span class="hidden dark:inline">☀</span>
    </button>
  </div>
</header>

<script>
  document.getElementById('switch-to-formal')?.addEventListener('click', () => {
    localStorage.setItem('siteMode', 'formal');
    window.location.href = '/';
  });
</script>
